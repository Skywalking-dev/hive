# Binance API (https://www.binance.com/en/my/settings/api-management)
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET_KEY=your_binance_secret_key

# Gmail OAuth (https://console.cloud.google.com/apis/credentials)
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token

# Slack (https://api.slack.com/apps)
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# WhatsApp Business (https://developers.facebook.com/apps)
WHATSAPP_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_ID=your_whatsapp_phone_id

# Gemini / Google AI (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key

# Supabase (from project settings)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Vercel (https://vercel.com/account/tokens)
VERCEL_TOKEN=your_vercel_token
